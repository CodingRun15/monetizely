# Postgres connection string used by the app + Prisma migrations.
# Get a free Neon Postgres database at https://neon.tech, then create a project/branch and
# copy its connection string into both vars below (DIRECT_URL only matters once you're using
# Neon's pooled endpoint for DATABASE_URL in production -- locally they can be identical).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
